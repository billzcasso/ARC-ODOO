<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root menu -->
    <menuitem id="menu_report_list_root" name="Report Lists" sequence="50"/>

    <!-- ===================== Report Balance (portfolio.investment) ===================== -->
    <record id="view_report_balance_tree" model="ir.ui.view">
        <field name="name">report.balance.tree</field>
        <field name="model">portfolio.investment</field>
        <field name="arch" type="xml">
            <list string="Báo cáo số dư" create="false" edit="false" delete="false">
                <field name="report_account_number"/>
                <field name="report_investor_name"/>
                <field name="report_id_number"/>
                <field name="report_fund_name"/>
                <field name="report_program_ticker"/>
                <field name="report_ccq_quantity"/>
                <field name="report_print_date"/>
            </list>
        </field>
    </record>

    <record id="view_report_balance_form" model="ir.ui.view">
        <field name="name">report.balance.form</field>
        <field name="model">portfolio.investment</field>
        <field name="arch" type="xml">
            <form string="Chi tiết báo cáo số dư" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="report_account_number" readonly="1"/>
                            <field name="report_investor_name" readonly="1"/>
                            <field name="report_phone_number" readonly="1"/>
                            <field name="report_email" readonly="1"/>
                            <field name="report_id_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="report_fund_name" readonly="1"/>
                            <field name="report_program_name" readonly="1"/>
                            <field name="report_program_ticker" readonly="1"/>
                            <field name="report_ccq_quantity" readonly="1"/>
                            <field name="report_print_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_report_balance_backend" model="ir.actions.act_window">
        <field name="name">Báo cáo số dư</field>
        <field name="res_model">portfolio.investment</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_report_balance_tree'), 'list'), (ref('view_report_balance_form'), 'form')]"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Không có dữ liệu báo cáo số dư để hiển thị.
            </p>
        </field>
    </record>

    <menuitem id="menu_report_balance_backend" name="Báo cáo số dư" parent="menu_report_list_root" action="action_report_balance_backend" sequence="10"/>

    <!-- ===================== Report Transaction (portfolio.transaction) ===================== -->
    <record id="view_report_transaction_tree" model="ir.ui.view">
        <field name="name">report.transaction.tree</field>
        <field name="model">portfolio.transaction</field>
        <field name="arch" type="xml">
            <list string="Báo cáo giao dịch" create="false" edit="false" delete="false">
                <field name="account_number_report"/>
                <field name="investor_name_report"/>
                <field name="transaction_code"/>
                <field name="order_type"/>
                <field name="fund_name"/>
                <field name="ccq_quantity"/>
                <field name="total_amount"/>
                <field name="trading_session"/>
            </list>
        </field>
    </record>

    <record id="view_report_transaction_form" model="ir.ui.view">
        <field name="name">report.transaction.form</field>
        <field name="model">portfolio.transaction</field>
        <field name="arch" type="xml">
            <form string="Chi tiết giao dịch" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="account_number_report" readonly="1"/>
                            <field name="investor_name_report" readonly="1"/>
                            <field name="id_number_report" readonly="1"/>
                            <field name="fund_name" readonly="1"/>
                            <field name="program_ticker" readonly="1"/>
                        </group>
                        <group>
                            <field name="transaction_code" readonly="1"/>
                            <field name="order_type" readonly="1"/>
                            <field name="ccq_quantity" readonly="1"/>
                            <field name="unit_price" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                            <field name="trading_session" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_report_transaction_backend" model="ir.actions.act_window">
        <field name="name">Báo cáo giao dịch</field>
        <field name="res_model">portfolio.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_report_transaction_tree'), 'list'), (ref('view_report_transaction_form'), 'form')]"/>
    </record>

    <menuitem id="menu_report_transaction_backend" name="Báo cáo giao dịch" parent="menu_report_list_root" action="action_report_transaction_backend" sequence="20"/>

    <!-- ===================== Investor Report ===================== -->
    <record id="view_investor_report_tree" model="ir.ui.view">
        <field name="name">investor.report.tree</field>
        <field name="model">investor.report</field>
        <field name="arch" type="xml">
            <list string="Danh sách nhà đầu tư">
                <field name="account_number"/>
                <field name="trading_account"/>
                <field name="customer_name"/>
                <field name="id_number"/>
                <field name="phone_number"/>
                <field name="email"/>
                <field name="status"/>
                <field name="customer_type"/>
                <field name="nationality_type"/>
                <field name="unit"/>
            </list>
        </field>
    </record>

    <record id="view_investor_report_form" model="ir.ui.view">
        <field name="name">investor.report.form</field>
        <field name="model">investor.report</field>
        <field name="arch" type="xml">
            <form string="Thông tin nhà đầu tư">
                <sheet>
                    <group>
                        <group>
                            <field name="account_number"/>
                            <field name="trading_account"/>
                            <field name="customer_name"/>
                            <field name="status"/>
                            <field name="customer_type"/>
                            <field name="nationality_type"/>
                            <field name="account_manager_id"/>
                        </group>
                        <group>
                            <field name="id_number"/>
                            <field name="id_issue_date"/>
                            <field name="id_issue_place"/>
                            <field name="permanent_address"/>
                            <field name="contact_address"/>
                            <field name="phone_number"/>
                            <field name="email"/>
                            <field name="unit"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_investor_report_backend" model="ir.actions.act_window">
        <field name="name">Danh sách nhà đầu tư</field>
        <field name="res_model">investor.report</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_investor_report_tree'), 'list'), (ref('view_investor_report_form'), 'form')]"/>
    </record>

    <menuitem id="menu_investor_report_backend" name="Danh sách NĐT" parent="menu_report_list_root" action="action_investor_report_backend" sequence="30"/>

    <!-- ===================== List Tenors & Interest Rates ===================== -->
    <record id="view_list_tenors_interest_rates_tree" model="ir.ui.view">
        <field name="name">list.tenors.interest.rate.tree</field>
        <field name="model">list.tenors.interest.rate</field>
        <field name="arch" type="xml">
            <list string="Kỳ hạn &amp; Lãi suất">
                <field name="product_name"/>
                <field name="product_creation_date"/>
                <field name="effective_date"/>
                <field name="end_date"/>
                <field name="term"/>
                <field name="interest_rate"/>
            </list>
        </field>
    </record>

    <record id="view_list_tenors_interest_rates_form" model="ir.ui.view">
        <field name="name">list.tenors.interest.rate.form</field>
        <field name="model">list.tenors.interest.rate</field>
        <field name="arch" type="xml">
            <form string="Kỳ hạn &amp; Lãi suất">
                <sheet>
                    <group>
                        <group>
                            <field name="product_name"/>
                            <field name="product_creation_date"/>
                            <field name="effective_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="term"/>
                            <field name="interest_rate"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_list_tenors_interest_rates_backend" model="ir.actions.act_window">
        <field name="name">Kỳ hạn &amp; Lãi suất</field>
        <field name="res_model">list.tenors.interest.rate</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_list_tenors_interest_rates_tree'), 'list'), (ref('view_list_tenors_interest_rates_form'), 'form')]"/>
    </record>

    <menuitem id="menu_list_tenors_interest_rates_backend" name="Kỳ hạn &amp; Lãi suất" parent="menu_report_list_root" action="action_list_tenors_interest_rates_backend" sequence="40"/>
</odoo>
