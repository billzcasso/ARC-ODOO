<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
            PayOS Default Configuration
            Tạo một bản ghi payos.config mặc định khi cài đặt module.
            Credentials có thể được cập nhật trong giao diện Settings > PayOS.
        -->
        <record id="payos_config_default" model="payos.config">
            <field name="name">Cấu hình mặc định</field>
            <field name="client_id"></field>
            <field name="api_key"></field>
            <field name="checksum_key"></field>
            <field name="base_url">https://api-merchant.payos.vn</field>
            <field name="is_active" eval="True"/>
            <field name="last_connection_status">not_tested</field>
        </record>
    </data>
</odoo>
